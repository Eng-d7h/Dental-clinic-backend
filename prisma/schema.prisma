
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// جدول الأطباء
model Doctor {
  id          Int      @id @default(autoincrement())
  name        String
  specialty   String
  createdAt   DateTime @default(now())

  schedules    DoctorSchedule[]
  appointments Appointment[]
  blockedSlots BlockedSlot[]
}

// جدول دوام كل طبيب (أي يوم، من أي وقت لأي وقت)
model DoctorSchedule {
  id        Int    @id @default(autoincrement())
  dayOfWeek Int    // 0 = الأحد, 1 = الاثنين ... 6 = السبت
  startTime String // مثال: "09:00"
  endTime   String // مثال: "17:00"

  doctor    Doctor @relation(fields: [doctorId], references: [id])
  doctorId  Int
}

// جدول الخدمات المتاحة بالعيادة
model Service {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  duration    Int      // مدة الخدمة بالدقائق
  createdAt   DateTime @default(now())

  appointmentServices AppointmentService[]
}

// جدول الحجوزات (الموعد نفسه)
model Appointment {
  id            Int      @id @default(autoincrement())
  patientName   String
  patientPhone  String
  date          DateTime
  startTime     String   // مثال: "10:30"
  status        String   @default("pending") // pending / confirmed / cancelled
  createdAt     DateTime @default(now())

  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  doctorId      Int

  appointmentServices AppointmentService[]
}

// جدول وسيط يربط الموعد بالخدمات (Many-to-Many)
model AppointmentService {
  id            Int         @id @default(autoincrement())

  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId Int

  service       Service     @relation(fields: [serviceId], references: [id])
  serviceId     Int
}

// جدول حساب المدير
model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

// جدول الأوقات اللي المدير يعطلها يدويًا (بدون حجز فعلي)
model BlockedSlot {
  id        Int      @id @default(autoincrement())
  date      DateTime
  startTime String
  reason    String?  // سبب اختياري، مثلاً "إجازة" أو "اجتماع"
  createdAt DateTime @default(now())

  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  doctorId  Int
}